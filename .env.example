# Client (safe to expose in browser when prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_ADMIN_WA_NUMBER=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only
EMAIL_FROM=
RESEND_API_KEY=

# Firebase Admin (server-only) - pick ONE approach
# Option A: point to a local JSON file (recommended for local dev)
GOOGLE_APPLICATION_CREDENTIALS=

# Option B: inline JSON (stringified)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option C: inline JSON base64 (stringified JSON, then base64)
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# Midtrans (server-only)
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CALLBACK_URL=
MIDTRANS_CALLBACK_URL_PENDING=
MIDTRANS_CALLBACK_URL_ERROR=

# App
SELF_SETUP_DOWNLOAD_URL=
